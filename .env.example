# KernelSense Environment Configuration

# ------------------------------------------------------------------------------
# Backend Settings
# ------------------------------------------------------------------------------
# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# FastAPI environment (dev, prod)
APP_ENV=dev
API_HOST=127.0.0.1
API_PORT=8000

# ------------------------------------------------------------------------------
# Database & Cache (Storage Layer)
# ------------------------------------------------------------------------------
# TimescaleDB Connection String (PostgreSQL)
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/kernelsense

# Redis Connection String
REDIS_URL=redis://localhost:6379/0

# ------------------------------------------------------------------------------
# Telemetry Collection
# ------------------------------------------------------------------------------
# Base sampling interval in seconds (default: 1.0)
SAMPLING_INTERVAL_SEC=1.0

# Feature flags for platform-specific capabilities (true/false)
ENABLE_EBPF=false          # Requires CAP_BPF / CAP_SYS_ADMIN (Linux)
ENABLE_PERF_EVENTS=false   # Requires CAP_PERFMON (Linux)
ENABLE_ETW=false           # Requires Administrator (Windows)

# ------------------------------------------------------------------------------
# AI & LLM Integration
# ------------------------------------------------------------------------------
# Path to ONNX model weights
LSTM_MODEL_PATH=./backend/ai/models/lstm_forecaster.onnx

# LLM API Configuration (Used for Research Tier explanations only)
# Supports 'openai' or 'anthropic'
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-xxxx...
ANTHROPIC_API_KEY=sk-ant-xxxx...
